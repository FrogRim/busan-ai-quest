rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Demo secret config is read only by Firebase Admin SDK inside Cloud Functions.
    // Never allow browser clients to read or write it.
    match /config/openai {
      allow read, write: if false;
    }

    // Browser key is intentionally served through the API so it can be paired
    // with domain/API restrictions and changed without rebuilding the frontend.
    match /config/googleMaps {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
